  "keyFeatures": [
    "PID 1 service manager with parallel service startup",
    "systemctl — unified service and system control CLI",
    "journald — structured binary logging with systemd-journalctl",
    "systemd-networkd — network configuration management",
    "systemd-resolved — DNS resolver with DNSSEC",
    "systemd-logind — seat, session, and login management",
    "udev — device manager and kernel event handler",
    "systemd-boot — UEFI boot manager",
    "Portable Services — bundled, sandboxed service images",
    "cgroup v2 resource control and delegation",
    "Encrypted credentials via TPM2 and /var/",
    "sd-bus — high-level D-Bus IPC library",
    "Varlink IPC protocol support",
    "systemd-homed — portable home directory management",
    "systemd-nspawn — container manager"
  ],
  "publicApiSurface": [
    "systemctl — service/unit management CLI",
    "journalctl — log query CLI",
    "networkctl — network status and control CLI",
    "resolvectl — DNS resolution CLI",
    "loginctl — session and seat management CLI",
    "busctl — D-Bus inspection and call CLI",
    "udevadm — udev management CLI",
    "portablectl — portable service management CLI",
    "machinectl — machine/container management CLI",
    "bootctl — boot manager CLI",
    "sd_bus_* — sd-bus D-Bus IPC API (libsystemd)",
    "sd_event_* — event loop API (libsystemd)",
    "sd_journal_* — journal read/write API (libsystemd)",
    "sd_notify() — service readiness notification API",
    "sd_login_* — login session query API (libsystemd)",
    "sd_id128_* — 128-bit ID handling API (libsystemd)",
    "libudev — udev device enumeration C library",
    "org.freedesktop.systemd1 D-Bus interface",
    "org.freedesktop.resolve1 D-Bus interface",
    "org.freedesktop.network1 D-Bus interface",
    "org.freedesktop.login1 D-Bus interface"
  ]
